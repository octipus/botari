{%- render 'inc-stylesheet', src: 's-sections.css' -%}

<section 
    class="newsletter" 
    {% unless section.settings.global_color_scheme %}color-scheme="{{ section.settings.color_scheme }}"{% endunless %}
>
	{% if section.settings.heading %}<h2 class="gs-title">{{ section.settings.heading }}</h2>{% endif %}

	<x-flex direction="column" jc="center" class="{{ section.settings.alignment | replace: 'left', 'start' | replace: 'right', 'end' | prepend: 'text-' }}">
        {%- for block in section.blocks -%}
        {% case block.type %}
            {%- when 'heading' -%}
            {%- if block.settings.subheading -%}
            <x-cell class="heading" {{ block.shopify_attributes }}><h3 class="h2">{{ section.settings.subheading }}</h3></x-cell>
            {%- endif -%}

            {%- when 'text' -%}
            {% if block.settings.text %}
            <x-cell class="description rte" {{ block.shopify_attributes }}>{{ block.settings.text }}</x-cell>
            {% endif %}

            {%- when 'form' -%}
            <x-cell class="form" {{ block.shopify_attributes }}>
                {%- render 'global-newsletter', class: 'section-newsletter', columns: block.settings.columns -%}
            </x-cell>

        {%- endcase -%}
        {%- endfor -%}
	</x-flex>
</section>

{% schema %}
{
  "name": "Newsltter",
  "disabled_on": { "groups": ["header", "footer", "aside"] },
  "presets": [
    {
      "name": "Newsletter",
      "category": "Content",
      "blocks": [ { "type": "heading" }, { "type": "text" }, { "type": "form" } ]
    }
  ],
  "settings": [
	{
      "type": "header",
      "content": "Newsletter",
      "info": "Subscribers will be added to your “accepts marketing” [customer list.](/admin/customers?query=&accepts_marketing=1)"
	},
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Newsletter"
      },
      {
        "type": "text_alignment",
        "id": "alignment",
        "label": "Text alignment",
        "default": "center"
      },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
        "type": "checkbox",
        "id": "global_color_scheme",
        "label": "Use global color scheme",
        "default": true
    },
    {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "coretex-1",
        "visible_if": "{{ section.settings.global_color_scheme == false }}"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Stay up to date on the latest product releases, special offers and news by signing up for our newsletter.</p>"
        }
      ]
    },
    {
      "type": "form",
      "name": "Form",
      "limit": 1,
      "settings": [
        {
            "type": "select",
            "id": "columns",
            "label": "Columns",
            "default": "2",
            "options": [
                { "value": "1", "label": "One" },
                { "value": "2", "label": "Two" }
            ]
        },
      ]
    }
  ]
}
{% endschema %}