{%- render 'inc-stylesheet', src: 's-sections.css' -%}

<section class="media-reveal" {% unless section.settings.global_color_scheme %}color-scheme="{{ section.settings.color_scheme }}"{% endunless %}>
    {%- if section.settings.heading != blank -%}<h2 class="gs-title">{{ section.settings.heading }}</h2>{%- endif -%}

    <component-loader>
        <coretex-reveal data-section-id="{{ section.id }}" data-default="0" data-activation="{{ section.settings.activation }}" data-hover-intent="{{ section.settings.hover_intent }}">
            <x-grid columns="2" columns-s="1" ai="start">

                <x-cell class="content {% if section.settings.sticky_content %} sticky sticky-none-s{% endif %}" order="{{ section.settings.alignment }}" order-s="1">
                    <x-flex class="triggers" direction="column" role="tablist">
                        {%- for block in section.blocks -%}
                            <x-flex ai="center" jc="between" class="trigger fullwidth" data-reveal-trigger="item-{{ block.id }}" {{ block.shopify_attributes }}>
                                {% if block.settings.thumbnail %}<x-cell class="thumbnail">
                                    {%- render 'inc-img',
                                        img: block.settings.image,
                                        imgMob: block.settings.image_mobile,
                                        widths: '80,100,180',
                                        loading: 'lazy',
                                        dynamic: true,
                                        fallback: true,
                                    -%}
                                </x-cell>{%endif %}
                                <x-cell class="meta" span="1">
                                    {%- if block.settings.heading != blank -%}<h3 class="h3">{{ block.settings.heading }}</h3>{%- endif -%}
                                    {%- if block.settings.description != blank -%}<p>{{ block.settings.description }}</p>{%- endif -%}
                                    {%- if block.settings.label != blank and block.settings.url != blank -%}<a href="{{ block.settings.url }}">{{ block.settings.label }}</a>{%- endif -%}
                                </x-cell>
                            </x-flex>
                        {%- endfor -%}
                    </x-flex>
                </x-cell>

                <x-cell order="2" order-s="2">
                    <div class="stage" {% unless section.settings.autoheight %}media-size="fixed"{% endunless %}>
                        {%- for block in section.blocks -%}
                            <div data-reveal-panel="item-{{ block.id }}" aria-hidden="true">
                                {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
                                    {%- render 'global-video',
                                        vid: block.settings.video,
                                        vidMobile: block.settings.video_mobile,
                                        loop: true,
                                        autoplay: true,
                                        muted: true,
                                        clickToPlay: true
                                    -%}
                                {%- else -%}
                                    {%- liquid
                                        # Optimize first section hero image
                                        assign fetchpriority = nil
                                        assign preload = false
                                        assign loading = 'lazy'

                                        if section.index == 1
                                            assign fetchpriority = 'high'
                                            assign preload = true
                                            assign loading = 'eager'
                                        endif
                                        render 'inc-img', img: block.settings.image, imgMob: block.settings.image_mobile, loading: loading, fetchpriority: fetchpriority, preload: preload, dynamic: true, fallback: true
                                    -%}
                                {%- endif -%}
                            </div>
                        {%- endfor -%}
                    </div>
                </x-cell>

            </x-grid>
        </coretex-reveal>
    </component-loader>
</section>

{% schema %}
{
    "name": "Media reveal",
    "disabled_on": { "groups": ["header", "footer", "aside"] },
    "max_blocks": 10,
    "presets": [
        {
            "name": "Media reveal",
            "category": "Media",
            "blocks": [
                { "type": "item" },
                { "type": "item" },
                { "type": "item" }
            ]
        }
    ],
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Media reveal",
            "info": "Leave blank to remove heading."
        },
        {
            "type": "header",
            "content": "Behavior"
        },
        {
            "type": "select",
            "id": "activation",
            "label": "Activation mode",
            "default": "auto",
            "options": [
                { "value": "auto", "label": "Auto (hover on desktop, click on mobile)" },
                { "value": "hover", "label": "Hover" },
                { "value": "click", "label": "Click" }
            ]
        },
        {
            "type": "range",
            "id": "hover_intent",
            "label": "Hover delay",
            "info": "Milliseconds before switching on hover.",
            "min": 0,
            "max": 500,
            "step": 10,
            "unit": "ms",
            "default": 120
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "select",
            "id": "alignment",
            "label": "Desktop trigger position",
            "default": "1",
            "options": [
                { "value": "1", "label": "Left" },
                { "value": "3", "label": "Right" }
            ]
        },
        {
            "type": "checkbox",
            "id": "sticky_content",
            "label": "Trigger content sticks - desktop",
            "default": true
        },
        {
            "type": "header",
            "content": "Media"
        },
        {
            "type": "checkbox",
            "id": "autoheight",
            "label": "Auto height",
            "default": true
        },
        {
            "type": "header",
            "content": "Appearance"
        },
        {
            "type": "checkbox",
            "id": "global_color_scheme",
            "label": "Use global color scheme",
            "default": true
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color scheme",
            "default": "coretex-1",
            "visible_if": "{{ section.settings.global_color_scheme == false }}"
        }
    ],
    "blocks": [
        {
            "type": "item",
            "name": "Item",
            "settings": [
                {
                    "type": "checkbox",
                    "id": "thumbnail",
                    "label": "Show thumbnail",
                    "default": false
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Feature"
                },
                {
                    "type": "textarea",
                    "id": "description",
                    "label": "Description"
                },
                {
                    "type": "header",
                    "content": "Button"
                },
                {
                    "type": "text",
                    "id": "label",
                    "label": "Label",
                    "default": "View"
                },
                {
                    "type": "url",
                    "id": "url",
                    "label": "Link"
                },
                {
                    "type": "header",
                    "content": "Media"
                },
                {
                    "type": "select",
                    "id": "media_type",
                    "label": "Media type",
                    "default": "image",
                    "options": [
                        { "value": "image", "label": "Image" },
                        { "value": "video", "label": "Video" }
                    ]
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Desktop",
                    "visible_if": "{{ block.settings.media_type == 'image' }}"
                },
                {
                    "type": "image_picker",
                    "id": "image_mobile",
                    "label": "Mobile",
                    "visible_if": "{{ block.settings.media_type == 'image' }}"
                },
                {
                    "type": "video",
                    "id": "video",
                    "label": "Desktop",
                    "visible_if": "{{ block.settings.media_type == 'video' }}"
                },
                {
                    "type": "video",
                    "id": "video_mobile",
                    "label": "Mobile",
                    "visible_if": "{{ block.settings.media_type == 'video' }}"
                }
            ]
        }
    ]
}
{% endschema %}
