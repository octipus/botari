{%- assign img = section.settings.image -%}

<newsletter-popup
    class="newsletter coretex-dialog"
    data-section-id="{{ section.id }}"
    data-expire="{{ section.settings.expire }}"
    data-trigger="{{ section.settings.open_trigger }}"
    data-delay="{{ section.settings.delay }}"
    data-scroll-type="{{ section.settings.scroll_type }}"
    data-scroll-percent="{{ section.settings.scroll_percent }}"
    data-scroll-px="{{ section.settings.scroll_px }}"
    data-design-mode="{{ request.design_mode }}"
    image-position="{{ section.settings.imagePosition }}"
    style="{{ section.settings.dialogWidth | prepend: '--dialogWidth:' | append: ';' }}"
    {% unless section.settings.global_color_scheme %}color-scheme="{{ section.settings.color_scheme }}"{% endunless %}
>
    {%- comment -%}<button open-newsletter>Open newsletter</button>{%- endcomment -%}

    <dialog dialog-position="{{ section.settings.dialogPosition}}" dialog-position-s="{{ section.settings.dialogPositionMob }}" class="{{ section.settings.text_align | replace: 'left', 'start' | replace: 'right', 'end' }} newsletterModal">
        <style>newsletter-popup.coretex-dialog dialog::backdrop { {%- unless section.settings.backdrop -%}background:transparent!important;backdrop-filter:none!important;{%- endunless -%} }</style>
        <x-flex jc="between" ai="center" class="header">
            <x-cell><h2 class="visually-hidden">{{ section.settings.heading }}</h2></x-cell>
            <x-cell><form>
                <button formmethod="dialog" value="cancel" class="has-icon is-circle" aria-label="{{ 'header.close' | t }}">
                    <span class="visually-hidden">{{ 'header.close' | t }}</span>
                    {%- render 'global-icon' with 'x' -%}
                </button>
            </form></x-cell>
        </x-flex>

        <x-grid columns="fit" class="contento" class="newsletterBody">
            {%- liquid
                if img != nil 
                    if section.settings.showImageMob != true
                        assign pclass = 'large-only'
                    endif
                    render 'inc-img', img: img, widths: '480,640,900', pclass: pclass
                endif
            -%}

            <x-flex direction="column" jc="center" class="modal" style="gap:var(--padding)">
                <x-cell order="1" class="heading">
                    <h3 class="h1">{{ section.settings.heading }}</h3>
                    {%- if section.settings.subheading != blank -%}<h4 class="h2">{{ section.settings.subheading }}</h4>{%- endif -%}
                </x-cell>
                <x-cell order="2" class="description">{{ section.settings.description }}</x-cell>
                <x-cell order="3" class="form">{%- render 'global-newsletter', location: 'popup', class: 'popup-newsletter' -%}</x-cell>
                {%- if section.settings.disclaimer != blank -%}
                <x-cell order="4" class="disclaimer"><small>{{ section.settings.disclaimer }}</small></x-cell>
                {%- endif -%}
            </x-flex>
        </x-grid>
    </dialog>
</newsletter-popup>

{% style %}
/*** 
    * [S] Overlay Newsletter
***/
newsletter-popup {
    display: block;

    &.coretex-dialog {
        --dialogRadius: var(--radius-2);
        --dialogPadding: 0px;
        --dialogMaxW: var(--dialogWidth);
        --dialogBorder: var(--globalBorder);
        --dialogH: fit-content;
    }

    .header {
        position: absolute; top: var(--margin); right: var(--margin); z-index: 2;

        button.is-blank svg.icon { transform: none; pointer-events: none }
    }

    .contento {
        gap: var(--globalBorderWidth);

        > *:not(picture) { margin: var(--padding) }
        picture { outline: var(--globalBorder); max-height: 700px }
        .disclaimer { color: color-mix(in oklch, currentColor, transparent 50%) }
    }

    &.hasformstatus .description { display: none!important }

    &:where([image-position="top"],[image-position-m="top"]) .contento picture img { object-fit: cover }

    @media (min-width: 778px) {
        &[image-position="right"] .contento picture { order: 2 }
        &[image-position="right"] .contento .modal { order: 1 }
        &[image-position="top"] .contento { --grid-tc: 1 }
        &[image-position="top"] .contento picture img { height: 40ch }
    }

    @media (max-width: 777px) {
        &.coretex-dialog.newsletter dialog { margin-inline: var(--margin) }

        .contento {
            --grid-tc: 1;

            picture { order: 1 }
            picture img { height: 100% }
            .modal { order: 2 }
        }
    }
}
{% endstyle %}

<script>
class newsletterPopup extends HTMLElement {
    constructor() {
        super();

        this.modal = this.querySelector('dialog');
        this.cookieName = 'bullet:newsletter';

        if (window.location.pathname === '/challenge') return; // On challenge page, close modal
        if (this.querySelector('[data-form-status]')) { this.open(); this.classList.add('hasformstatus') } // On failure or success, open modal
        if (!this.getCookie(this.cookieName) || this.dataset.designMode === 'true') this.init();

        // Register event listeners
        {% if request.design_mode %}
        if (Shopify.designMode) {
          document.addEventListener('shopify:section:load',(event) => filterShopifyEvent(event, this, this.open.bind(this)));
          document.addEventListener('shopify:section:select',(event) => filterShopifyEvent(event, this, this.open.bind(this)));
          document.addEventListener('shopify:section:deselect',(event) => filterShopifyEvent(event, this, this.close.bind(this)));
        }
        {%- endif -%}

        document.querySelectorAll('[open-newsletter]').forEach((button) => button.addEventListener('click', this.open.bind(this)));
        document.querySelectorAll('[value="cancel"], [close-newsletter]').forEach((button) => button.addEventListener('click', this.close.bind(this)));
    }

    init() {
        if (Shopify && Shopify.designMode) return;
        if (this.getCookie(this.cookieName)) return;

        const trigger = this.dataset.trigger;

        if (trigger === 'delay') {
            this._delayTimer = setTimeout(() => {
                if (!this.modal.hasAttribute('open')) this.open();
            }, parseInt(this.dataset.delay) * 1000);
        }

        if (trigger === 'exit_intent') {
            this._onExitIntent = (e) => {
                if (e.clientY <= 0) {
                    this.open();
                    document.removeEventListener('mouseout', this._onExitIntent);
                }
            };
            document.addEventListener('mouseout', this._onExitIntent);
        }

        if (trigger === 'scroll') {
            this._onScroll = () => {
                const scrollType = this.dataset.scrollType;
                const scrolled = window.scrollY;
                let threshold;

                if (scrollType === 'percent') {
                    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
                    threshold = (parseInt(this.dataset.scrollPercent) / 100) * docHeight;
                } else {
                    threshold = parseInt(this.dataset.scrollPx);
                }

                if (scrolled >= threshold) {
                    this.open();
                    window.removeEventListener('scroll', this._onScroll);
                }
            };
            window.addEventListener('scroll', this._onScroll, { passive: true });
        }
    }


    open() {
        if (!this.modal.hasAttribute('open')) {
            this.modal.showModal();
            this.removeCookie(this.cookieName);
            this._cleanupTriggers();
        }
    }

    _cleanupTriggers() {
        if (this._delayTimer) clearTimeout(this._delayTimer);
        if (this._onExitIntent) document.removeEventListener('mouseout', this._onExitIntent);
        if (this._onScroll) window.removeEventListener('scroll', this._onScroll);
    }

    close() {
        this.modal.close();
        if (this.dataset.designMode === 'true') {
            this.removeCookie(this.cookieName);
            return;
        } else { history.replaceState({}, document.title, window.location.pathname) }

        this.setCookie(this.cookieName, this.dataset.expire);
    }

    getCookie(name) { const match = document.cookie.match(`(^|;)\\s*${name}\\s*=\\s*([^;]+)`); return match ? match[2] : null;}
    setCookie(name, expire) { document.cookie = `${name}=true; max-age=${expire * 24 * 60 * 60}; path=/`; }
    removeCookie(name) { document.cookie = `${name}=; max-age=0`; }
}

customElements.define('newsletter-popup', newsletterPopup);
</script>

{% schema %}
{
    "name": "Newsletter",
    "limit": 1,
    "enabled_on": { "groups": ["aside"] },
    "settings": [
      {
        "type": "header",
        "content": "Newsletter",
        "info": "Subscribers will be added to your 'accepts marketing' [customer list](/admin/customers?query=&accepts_marketing=1)."
      },
      {
        "type": "header",
        "content": "Triggers"
      },
      {
        "type": "select",
        "id": "open_trigger",
        "label": "Open trigger",
        "default": "delay",
        "options": [
            { "value": "delay", "label": "Time delay" },
            { "value": "exit_intent", "label": "Exit intent" },
            { "value": "scroll", "label": "Scroll position" }
        ]
      },
      {
        "type": "paragraph",
        "content": "Exit intent works only on desktop devices.",
        "visible_if": "{{ section.settings.open_trigger == 'exit_intent' }}"
      },
      {
        "type": "range",
        "id": "delay",
        "label": "Delay",
        "min": 1,
        "max": 60,
        "unit": "sec",
        "step": 1,
        "default": 5,
        "visible_if": "{{ section.settings.open_trigger == 'delay' }}"
      },
      {
        "type": "select",
        "id": "scroll_type",
        "label": "Scroll type",
        "default": "percent",
        "options": [
            { "value": "percent", "label": "Percentage (%)" },
            { "value": "px", "label": "Pixels (px)" }
        ],
        "visible_if": "{{ section.settings.open_trigger == 'scroll' }}"
      },
      {
        "type": "range",
        "id": "scroll_percent",
        "label": "Scroll position",
        "min": 5,
        "max": 100,
        "unit": "%",
        "step": 5,
        "default": 50,
        "visible_if": "{{ section.settings.open_trigger == 'scroll' and section.settings.scroll_type == 'percent' }}"
      },
      {
        "type": "range",
        "id": "scroll_px",
        "label": "Scroll position",
        "min": 100,
        "max": 5000,
        "unit": "px",
        "step": 100,
        "default": 500,
        "visible_if": "{{ section.settings.open_trigger == 'scroll' and section.settings.scroll_type == 'px' }}"
      },
      {
        "type": "range",
        "id": "expire",
        "label": "Frequency",
        "info": "Number of days before a closed popup reappears.",
        "min": 1,
        "max": 60,
        "unit": "day",
        "step": 1,
        "default": 7
      },
      {
        "type": "header",
        "content": "Dialog"
      },
      {
        "type": "select",
        "id": "dialogWidth",
        "label": "Width",
        "default": "90ch",
        "options": [
            { "value": "90ch", "label": "Normal" },
            { "value": "65ch", "label": "Compact" }
        ]
      },
      {
        "type": "select",
        "id": "dialogPosition",
        "label": "Position - desktop",
        "default": "center",
        "options": [
            { "value": "center", "label": "Center" },
            { "value": "top left", "label": "Top left" },
            { "value": "top center", "label": "Top center" },
            { "value": "top right", "label": "Top right" },
            { "value": "bottom left", "label": "Bottom left" },
            { "value": "bottom center", "label": "Bottom center" },
            { "value": "bottom right", "label": "Bottom right" }
        ]
      },
      {
        "type": "select",
        "id": "dialogPositionMob",
        "label": "Position - mobile",
        "default": "bottom",
        "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
        ]
      },
      {
        "type": "header",
        "content": "Image"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "checkbox",
        "id": "showImageMob",
        "label": "Show - mobile",
        "default": false
      },
      {
        "type": "select",
        "id": "imagePosition",
        "label": "Position - desktop",
        "default": "top",
        "info": "Mobile defaults to top.",
        "options": [
            { "value": "top", "label": "Top" },
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
        ]
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Newsletter"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Stay up to date on the latest product releases, special offers and news by signing up for our newsletter."
      },
      {
        "type": "richtext",
        "id": "disclaimer",
        "label": "Disclaimer"
      },
      {
        "type": "text_alignment",
        "id": "text_align",
        "label": "Alignment",
        "default": "left"
      },
      {
          "type": "header",
          "content": "Appearance"
      },
      {
        "type": "checkbox",
        "id": "backdrop",
        "label": "Show backdrop",
        "default": false
      },
      {
          "type": "checkbox",
          "id": "global_color_scheme",
          "label": "Use global color scheme",
          "default": true
      },
      {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Color scheme",
          "default": "coretex-1",
          "visible_if": "{{ section.settings.global_color_scheme == false }}"
      }
    ],
    "presets": [
        { "name": "Newsletter" }
    ]
}
{% endschema %}