{%- render 'inc-stylesheet', src: 's-sections.css' -%}

<section class="store-locator" {% unless section.settings.global_color_scheme %}color-scheme="{{ section.settings.color_scheme }}"{% endunless %}>
    {%- if section.settings.heading != blank -%}<h2 class="gs-title">{{ section.settings.heading }}</h2>{%- endif -%}

    <component-loader>
        <coretex-reveal data-section-id="{{ section.id }}" data-default="0" data-activation="{{ section.settings.activation }}" data-hover-intent="{{ section.settings.hover_intent }}">
            <x-grid columns="2" columns-s="1">

                <x-cell class="content" order="{{ section.settings.alignment }}" order-s="2">
                    <x-flex class="triggers" direction="column" role="tablist">
                        {%- for block in section.blocks -%}
                            {%- if block.type == 'group' -%}
                                {%- if block.settings.heading != blank -%}<x-cell class="locationGroup"><h3 class="h3" {{ block.shopify_attributes }}>{{ block.settings.heading }}</h3></x-cell>{%- endif -%}
                            {%- else -%}
                                <details class="locationItem"  name="{{ section.id }}" {% if block.settings.open %}open{% endif %} data-reveal-trigger="item-{{ block.id }}" {{ block.shopify_attributes }}>
                                    <summary class="dropdown-caret button is-blank text-normal text-nonecase">
                                        <span>{%- render 'global-icon' with 'marker-pin' -%}&nbsp;{{ block.settings.heading }}</span>
                                    </summary>
                                    {%- if block.settings.description != blank -%}<details-menu class="rte">{{ block.settings.description }}</details-menu>{%- endif -%}
                                </details>
                            {%- endif -%}
                        {%- endfor -%}
                    </x-flex>
                </x-cell>

                <x-cell order="2" order-s="1">
                    <div class="stage large-only">
                        {%- for block in section.blocks -%}
                            {%- if block.type == 'location' -%}
                            <div data-reveal-panel="item-{{ block.id }}" aria-hidden="true">
                                {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
                                    {%- render 'global-video',
                                        vid: block.settings.video,
                                        vidMobile: block.settings.video_mobile,
                                        loop: true,
                                        autoplay: true,
                                        muted: true,
                                        clickToPlay: true
                                    -%}
                                {%- else -%}
                                    {%- liquid
                                        # Optimize first section hero image
                                        assign fetchpriority = nil
                                        assign preload = false
                                        assign loading = 'lazy'

                                        if section.index == 1
                                            assign fetchpriority = 'high'
                                            assign preload = true
                                            assign loading = 'eager'
                                        endif
                                        render 'inc-img', img: block.settings.image, imgMob: block.settings.image_mobile, loading: loading, fetchpriority: fetchpriority, preload: preload, dynamic: true, fallback: true
                                    -%}
                                {%- endif -%}
                            </div>
                            {%- endif -%}
                        {%- endfor -%}
                    </div>
                </x-cell>

            </x-grid>
        </coretex-reveal>
    </component-loader>
</section>

{% schema %}
{
    "name": "Store locator",
    "disabled_on": { "groups": ["header", "footer", "aside"] },
    "presets": [
        {
            "name": "Store locator",
            "category": "Content",
            "blocks": [
                { "type": "group" },
                { "type": "location" },
                { "type": "location" },
                { "type": "location" },
                { "type": "group" },
                { "type": "location" }
            ]
        }
    ],
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Store locator",
            "info": "Leave blank to remove heading."
        },
        {
            "type": "header",
            "content": "Behavior"
        },
        {
            "type": "select",
            "id": "activation",
            "label": "Activation mode",
            "default": "auto",
            "options": [
                { "value": "auto", "label": "Auto (hover on desktop, click on mobile)" },
                { "value": "hover", "label": "Hover" },
                { "value": "click", "label": "Click" }
            ]
        },
        {
            "type": "range",
            "id": "hover_intent",
            "label": "Hover delay",
            "info": "Milliseconds before switching on hover.",
            "min": 0,
            "max": 500,
            "step": 10,
            "unit": "ms",
            "default": 120
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "select",
            "id": "alignment",
            "label": "Desktop trigger position",
            "default": "1",
            "options": [
                { "value": "1", "label": "Left" },
                { "value": "3", "label": "Right" }
            ]
        },
        {
            "type": "header",
            "content": "Appearance"
        },
        {
            "type": "checkbox",
            "id": "global_color_scheme",
            "label": "Use global color scheme",
            "default": true
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color scheme",
            "default": "coretex-1",
            "visible_if": "{{ section.settings.global_color_scheme == false }}"
        }
    ],
    "blocks": [
        {
            "type": "group",
            "name": "Group",
            "settings": [
                {
                    "type": "paragraph",
                    "content": "Use groups to organize locations by city, region, country, or other category."
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Location group"
                }
            ]
        },
        {
            "type": "location",
            "name": "Location",
            "settings": [
                {
                    "type": "checkbox",
                    "id": "open",
                    "label": "Open by default",
                    "default": false
                },
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Location"
                },
                {
                    "type": "richtext",
                    "id": "description",
                    "label": "Description",
                    "default": "<p>Contact information goes here.</p>"
                },
                {
                    "type": "header",
                    "content": "Media"
                },
                {
                    "type": "select",
                    "id": "media_type",
                    "label": "Media type",
                    "default": "image",
                    "options": [
                        { "value": "image", "label": "Image" },
                        { "value": "video", "label": "Video" }
                    ]
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Desktop",
                    "visible_if": "{{ block.settings.media_type == 'image' }}"
                },
                {
                    "type": "image_picker",
                    "id": "image_mobile",
                    "label": "Mobile",
                    "visible_if": "{{ block.settings.media_type == 'image' }}"
                },
                {
                    "type": "video",
                    "id": "video",
                    "label": "Desktop",
                    "visible_if": "{{ block.settings.media_type == 'video' }}"
                },
                {
                    "type": "video",
                    "id": "video_mobile",
                    "label": "Mobile",
                    "visible_if": "{{ block.settings.media_type == 'video' }}"
                }
            ]
        }
    ]
}
{% endschema %}
