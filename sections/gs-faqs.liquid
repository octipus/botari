{%- render 'inc-stylesheet', src: 's-sections.css' -%}

<section class="faq" {% unless section.settings.global_color_scheme %}color-scheme="{{ section.settings.color_scheme }}"{% endunless %}>
<h2 class="gs-title">{{ section.settings.heading }}</h2>
<x-grid columns="3" columns-s="1">
{%- for block in section.blocks -%}
    <x-cell {{ block.shopify_attributes }}>
        <details {% if block.settings.expandAnswer == true %}open{% endif %} itemscope itemtype="https://schema.org/Question">
            <summary data-question="question" itemprop="name" class="dropdown-caret">{{ block.settings.title | escape }}</summary>
            <div data-answer="answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                <div itemprop="text" class="rte">{{ block.settings.answer }}</div>
            </div>
        </details>
    </x-cell>
{%- endfor -%}
</x-grid>
{%- if section.settings.all != empty -%}
    <div class="loadmore"><a href="{{ section.settings.link }}" class="no-style">{{ section.settings.all }}</a></div>
{%- endif -%}
</section>

{% schema %}
{
  "name": "FAQ",
  "max_blocks": 12,
  "disabled_on": { "groups": ["header", "footer", "aside"] },
  "presets": [
    {
      "name": "FAQ",
      "category": "Content",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ],
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "all",
      "label": "Button label",
      "default": "View all FAQ"
    },
    {
      "id": "link",
      "type": "url",
      "label": "Button link"
    },
    {
        "type": "header",
        "content": "Appearance"
    },
    {
        "type": "checkbox",
        "id": "global_color_scheme",
        "label": "Use global color scheme",
        "default": true
    },
    {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "coretex-1",
        "visible_if": "{{ section.settings.global_color_scheme == false }}"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Question",
          "default": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Answer</p>"
        },
        {
          "type": "checkbox",
          "id": "expandAnswer",
          "label": "Expand by default",
          "default": false
        }
      ]
    }
  ]
}
{% endschema %}