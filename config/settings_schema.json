			{
				"type": "text_alignment",
				"id": "buttonAlign",
				"label": "Text alignment",
				"default": "center"
			},
			{
				"type": "header",
				"content": "Inputs"
			},
			{
				"type": "select",
				"id": "boxTransform",
				"label": "Text case",
				"default": "none",
				"options": [
					{
						"value": "none",
						"label": "Default"
					},
					{
						"value": "uppercase",
						"label": "Uppercase"
					},
					{
						"value": "lowercase",
						"label": "Lowercase"
					}
				]
			},
			{
				"type": "text_alignment",
				"id": "boxAlign",
				"label": "Text alignment",
				"default": "left"
			},
			{
				"type": "header",
				"content": "Custom fonts"
			},
			{
				"type": "checkbox",
				"id": "useCustomFont",
				"label": "Enable custom fonts",
				"default": false,
				"info": "[Learn how](http://docs.openthinking.net/themes/bullet/fonts) to upload your fonts."
			}
		]
