[
	{
		"name": "theme_info",
		"theme_name": "Bullet",
		"theme_version": "6.0.0",
		"theme_author": "OpenThinking",
		"theme_documentation_url": "https://docs.openthinking.net/themes/bullet/",
		"theme_support_url": "https://openthinking.net/support/"
	},
	{
		"name": "Layout",
		"settings": [
			{
				"type": "header",
				"content": "Site width"
			},
			{
				"type": "checkbox",
				"id": "boxedLayout",
				"label": "Fixed max width",
				"default": false
			},
			{
				"type": "range",
				"label": "Max width on desktop",
				"id": "boxedLayoutWidth",
				"min": 1200,
				"max": 3000,
				"step": 100,
				"unit": "px",
				"default": 1200,
				"visible_if": "{{ settings.boxedLayout }}"
			},
			{
				"type": "header",
				"content": "Border"
			},
			{
				"type": "range",
				"label": "Width",
				"id": "globalBorderWidth",
				"min": 0,
				"max": 4,
				"step": 1,
				"unit": "px",
				"default": 1
			},
			{
				"type": "select",
				"id": "globalBorderRadius",
				"label": "Round corners",
				"default": "var(--space-0)",
				"options": [
					{ "value": "var(--space-0)", "label": "None" },
					{ "value": "var(--space-1)", "label": "Small" },
					{ "value": "var(--space-2)", "label": "Medium" },
					{ "value": "var(--space-10)", "label": "Large" }
				]
			},
			{
				"type": "header",
				"content": "Images"
			},
			{
				"type": "select",
				"id": "globalImgRadius",
				"label": "Round corners",
				"default": "0",
				"options": [
					{
						"value": "0",
						"label": "None"
					},
					{
						"value": "1.5rem",
						"label": "Small"
					},
					{
						"value": "3rem",
						"label": "Medium"
					},
					{
						"value": "5rem",
						"label": "Large"
					},
					{
						"value": "100%",
						"label": "Oval"
					},
					{
						"value": "100vw",
						"label": "Pill"
					}
				]
			},
			{
				"type": "select",
				"id": "media_padding",
				"label": "Padding",
				"default": "none",
				"options": [
					{
						"value": "none",
						"label": "None"
					},
					{
						"value": "small",
						"label": "Small"
					},
					{
						"value": "large",
						"label": "Large"
					}
				]
			},
			{
				"type": "header",
				"content": "Iconography"
			},
			{
				"type": "select",
				"id": "iconsStroke",
				"label": "Icon stroke",
				"default": "1",
				"options": [
					{ "value": "1", "label": "Thin" },
					{ "value": "2", "label": "Thick" }
				]
			},
			{
				"type": "header",
				"content": "Dropdown caret"
			},
			{
				"type": "select",
				"id": "caretType",
				"label": "Caret type",
				"default": "caret",
				"options": [
					{ "value": "caret", "label": "Caret" },
					{ "value": "arrow", "label": "Arrow" },
					{ "value": "dot", "label": "Dot" }
				]
			},
			{
				"type": "header",
				"content": "Accessibility"
			},
			{
				"type": "select",
				"id": "a11yFocusStyles",
				"label": "Focus styles",
				"info": "Customize how focus indicators appear for accessibility.",
				"default": "defaults",
				"options": [
					{ "value": "a11y-off", "label": "None" },
					{ "value": "defaults", "label": "Browser defaults" },
					{ "value": "a11y-custom", "label": "Theme defaults" }
				]
			},
			{
				"type": "header",
				"content": "Markets dialog",
				"info": "Controls the appearance of the country/region and language selector dialog."
			},
			{
				"type": "select",
				"id": "markets_dialog_position",
				"label": "Position",
				"default": "center",
				"options": [
					{ "value": "center", "label": "Center" },
					{ "value": "top right", "label": "Right" }
				]
			}
		]
	},
	{
