				]
			},
			{
				"type": "header",
				"content": "Buttons"
			},
			{
				"type": "select",
				"id": "buttonTransform",
				"label": "Text case",
				"default": "uppercase",
				"options": [
					{
						"value": "none",
						"label": "Default"
					},
					{
						"value": "uppercase",
						"label": "Uppercase"
					},
					{
						"value": "lowercase",
						"label": "Lowercase"
					}
				]
			},
			{
				"type": "select",
				"id": "buttonWeight",
