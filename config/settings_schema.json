	{
		"name": "Breadcrumbs",
		"settings": [
			{
				"type": "checkbox",
				"id": "showBreadcrumbs",
				"label": "Enable",
				"default": false
			},
			{
				"type": "paragraph",
				"content": "Breadcrumbs are static and unaware of the user's navigation. On product pages, the first collection listed in alphabetical order is shown by default."
			},
			{
				"type": "select",
				"id": "breadcrumbsParentCollection",
				"label": "Parent category",
				"default": "collection",
				"info": "Change product pages parent category. [Learn more](https://docs.openthinking.net/themes/bullet/kb/breadcrumbs/)",
				"options": [
					{ "value": "collection", "label": "Collection" },
					{ "value": "collectionAware", "label": "Collection-aware" },
					{ "value": "vendor", "label": "Vendor" }
				]
			},
			{
				"type": "select",
				"id": "breadcrumbSeparator",
				"label": "Breadcrumb separator",
				"default": "default",
				"options": [
					{ "value": "default", "label": "› (Right-pointing quotation mark)" },
					{ "value": "greater", "label": "> (Greater-than sign)" },
					{ "value": "bullet", "label": "• (Bullet)" },
					{ "value": "dot", "label": "· (Dot)" },
					{ "value": "slash", "label": "/ (Slash)" },
					{ "value": "endash", "label": "- (En dash)" },
					{ "value": "emdash", "label": "— (Em dash)" },
					{ "value": "wave", "label": "~ (Wave dash)" }
				]
			}
		]
	},
	{
		"name": "Search",
		"settings": [
			{
				"type": "paragraph",
				"content": "To enhance the search functionality of your store and tailor the results to your preference, install the Search & Discovery app. [Learn more](https://help.shopify.com/en/manual/online-store/storefront-search)"
			},
			{
				"type": "header",
				"content": "Dialog"
			},
            {
                "type": "select",
                "id": "search_dialog_layout",
                "label": "Layout",
                "default": "default",
                "options": [
                    { "value": "default", "label": "Page overlay" },
                    { "value": "light", "label": "Below header" }
                ]
            },
			{
				"type": "header",
				"content": "Suggested links",
				"info": "Displayed before any search input."
			},
			{
				"type": "link_list",
				"id": "search_suggested_links",
				"label": "Links",
				"info": "Dropdown items won’t appear in this menu."
			},
			{
				"type": "text",
				"id": "search_suggested_links_title",
				"label": "Title",
				"visible_if": "{{ settings.search_suggested_links != blank }}"
			},
			{
				"type": "header",
				"content": "Suggested products",
				"info": "Displayed before any search input."
			},
			{
				"type": "collection",
				"id": "search_suggested_products",
				"label": "Products",
				"info": "Collection to pull products from for suggestions."
			},
			{
				"type": "text",
				"id": "search_suggested_products_title",
				"label": "Title",
				"visible_if": "{{ settings.search_suggested_products != blank }}",
				"info": "Leave blank to use the collection title."
			},
			{
				"type": "range",
				"id": "search_suggested_products_limit",
				"min": 3,
				"max": 10,
				"step": 1,
				"default": 5,
				"label": "Limit",
				"info": "Controls how many products are shown in the suggestion area.",
				"visible_if": "{{ settings.search_suggested_products != blank }}"
			},
			{
				"type": "header",
				"content": "Predictive search",
				"info": "Results appear instantly as you type."
			},
			{
				"type": "checkbox",
				"id": "predictive_search_enabled",
				"label": "Enable",
				"default": true
			},
			{
				"type": "checkbox",
				"id": "predictive_search_show_vendor",
				"label": "Show vendor",
				"default": false,
				"visible_if": "{{ settings.predictive_search_enabled }}"
			},
			{
				"type": "checkbox",
				"id": "predictive_search_show_price",
				"label": "Show price",
				"default": true,
				"visible_if": "{{ settings.predictive_search_enabled }}"
			},
            {
                "type": "header",
                "content": "Appearance"
            },
            {
                "type": "checkbox",
                "id": "search_global_color_scheme",
                "label": "Use global color scheme",
                "default": true
            },
            {
                "type": "color_scheme",
                "id": "search_color_scheme",
                "label": "Color scheme",
                "default": "coretex-1",
                "visible_if": "{{ settings.search_global_color_scheme == false }}"
            }
		]
	},
	{
		"name": "Cart",
		"settings": [
			{
				"type": "select",
				"id": "cart_type",
				"label": "Cart type",
				"default": "drawer",
