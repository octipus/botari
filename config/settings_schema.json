						"label": "Background",
                        "alpha": true
					},
					{
						"type": "color",
						"id": "input_bg_hover",
						"label": "Background on interaction",
                        "alpha": true
					},
					{
						"type": "color",
						"id": "input_color",
						"label": "Text"
					},
					{
						"type": "color",
						"id": "input_color_hover",
						"label": "Text on interaction"
					},
					{
						"type": "color",
						"id": "input_border",
						"label": "Border",
                        "alpha": true
					},
					{
						"type": "color",
						"id": "input_border_hover",
						"label": "Border on interaction",
                        "alpha": true
					},
					{
						"type": "header",
						"content": "Buttons"
					},
					{
						"type": "color",
						"id": "button_bg",
						"label": "Background",
                        "alpha": true
					},
					{
						"type": "color",
						"id": "button_bg_hover",
						"label": "Background on interaction",
                        "alpha": true
					},
					{
						"type": "color",
						"id": "button_color",
						"label": "Text"
					},
					{
						"type": "color",
						"id": "button_color_hover",
						"label": "Text on interaction"
					},
					{
						"type": "color",
						"id": "button_border",
						"label": "Border",
                        "alpha": true
					},
					{
						"type": "color",
						"id": "button_border_hover",
						"label": "Border on interaction",
                        "alpha": true
					},
                    {
                        "type": "header",
                        "content": "Accents",
                        "info": "On product cards affects badges, titles, price, and other accent elements."
                    },
                    {
                        "type": "color",
                        "id": "accent_bg",
                        "label": "Background",
                        "alpha": true
                    },
                    {
                        "type": "color",
                        "id": "accent_color",
                        "label": "Text"
                    },
                    {
                        "type": "color",
                        "id": "accent_border",
                        "label": "Border",
                        "alpha": true
                    }
				],
				"role": {
					"background": "background",
					"text": "text",
					"icons": "text",
					"links": "link",
					"primary_button": "button_bg",
					"on_primary_button": "button_color",
					"primary_button_border": "button_border",
					"secondary_button": "input_bg",
					"on_secondary_button": "input_color",
					"secondary_button_border": "input_border"
				}
			},
			{
				"type": "header",
				"content": "Global",
				"info": "Default color scheme is applied to all elements across your online store."
			},
			{
				"type": "color_scheme",
				"id": "global_color_scheme",
				"default": "coretex-1",
				"label": "Color scheme"
			},
			{
				"type": "header",
				"content": "Overlay backdrop",
				"info": "This setting is applied to all backdrop elements across your online store."
			},
			{
				"type": "color",
				"id": "overlayBg",
				"label": "Background",
				"default": "#FFFFFF",
				"alpha": true
			},
			{
				"type": "range",
				"label": "Blur",
				"id": "overlayBlur",
				"min": 0,
				"max": 40,
				"step": 1,
				"default": 0
			}
		]
	},
	{
		"name": "Typography",
		"settings": [
			{
				"type": "header",
				"content": "Body"
			},
			{
				"type": "font_picker",
				"label": "Font",
				"id": "bodyFontFamily",
				"default": "inter_n4",
				"info": "Selecting a different font can affect the speed of your store. [Learn more about system fonts.](https://help.shopify.com/en/manual/online-store/store-speed/improving-speed#fonts)"
			},
			{
				"type": "range",
				"id": "fontSize",
				"min": 80,
				"max": 130,
				"step": 5,
				"unit": "%",
